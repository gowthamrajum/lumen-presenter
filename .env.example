# ESV API key — enables the ESV option in the Psalms source.
#
# Get a FREE key by registering your church/ministry at https://api.esv.org
# (Crossway licenses the ESV free for non-commercial church use).
#
# Then copy this file to `.env` and paste your key:
#     cp .env.example .env
#     # edit .env and set ESV_API_KEY=...
#
# `.env` is gitignored and is NOT bundled into the built app, so the key stays
# private (Crossway forbids publishing it, and this repo/releases are public).
# The app reads it at runtime — no in-app entry needed.
ESV_API_KEY=
